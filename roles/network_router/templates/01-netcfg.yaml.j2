network:
  version: 2
  ethernets:
    enp0s1:
      dhcp4: false
      dhcp6: false
      mtu: {{ overlay_mtu + 50 }}
  vlans:
    vlan{{ mgmt_vlan }}:
      id: {{ mgmt_vlan }}
      link: enp0s1
      mtu: {{ overlay_mtu + 50 }}
      addresses:
        - {{ mgmt_ip_v4 }}
        - {{ mgmt_ip_v6 }}
      routes:
        - to: default
          via: {{ mgmt_gw }}
      nameservers:
        addresses: [172.16.0.2, 9.9.9.9]

{% for vlan in tenant_vlans %}
    vlan{{ vlan.id }}:
      id: {{ vlan.id }}
      link: enp0s1
      mtu: {{ overlay_mtu + 50 }}
      addresses:
        - {{ vlan.ip }}
      routes:
        - to: default
          via: {{ mgmt_gw }}
          table: {{ vlan.table }}
{% if vlan.id == 681 %}
        - to: 192.0.2.0/24
          via: 172.18.169.10
{% endif %}
      routing-policy:
        - to: 10.0.0.0/8
          table: 254
          priority: 10
        - to: 172.18.0.0/16
          table: 254
          priority: 15
        - from: {{ vlan.network }}
          table: {{ vlan.table }}
          priority: 20
        - mark: {{ vlan.mark }}
          from: 0.0.0.0/0
          table: {{ vlan.table }}
          priority: 30
{% endfor %}
